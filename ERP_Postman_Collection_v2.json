    {
      "name": "1. Auth Service",
      "item": [
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "  console.log('Token saved:', res.data.access_token);",
                  "}",
                  "pm.test('Registration successful', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sammy Idana\",\n  \"email\": \"admin.new@erp.gh\",\n  \"password\": \"admin2468\",\n  \"role\": \"system_admin\"\n}"
            },
            "url": { "raw": "{{base_auth}}/auth/register", "host": ["{{base_auth}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "  console.log('Token saved:', res.data.access_token);",
                  "}",
                  "pm.test('Login successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin.test@erp.gh\",\n  \"password\": \"admin2468\"\n}"
            },
            "url": { "raw": "{{base_auth}}/auth/login", "host": ["{{base_auth}}"], "path": ["auth", "login"] }
          }
